# AO Environment Variables — copy to .env and fill in your values

# ── LLM provider — choose ONE block ────────────────────────────────────────

# Option A: OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini

# Option B: Azure OpenAI
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Option C: Ollama (local, no cost)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:1b

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ao:localdev@localhost:5432/ao

# ── Langfuse observability ──────────────────────────────────────────────────
# Leave blank to disable tracing.
# Create a project at http://localhost:3000 first, then paste keys here.
LANGFUSE_HOST=http://localhost:3000
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
