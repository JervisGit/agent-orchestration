FROM python:3.13-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 curl \
    && rm -rf /var/lib/apt/lists/*

COPY ao-core/ ./ao-core/
COPY examples/rag_search/backend/ ./backend/
COPY examples/rag_search/frontend/ ./frontend/
COPY examples/rag_search/ao-manifest.yaml ./ao-manifest.yaml

RUN pip install --no-cache-dir \
    ./ao-core \
    fastapi \
    "uvicorn[standard]" \
    python-multipart \
    python-dotenv \
    python-json-logger

ENV PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD curl -f http://localhost:8002/healthz || exit 1

CMD ["uvicorn", "backend.app:app", "--host", "0.0.0.0", "--port", "8002", "--workers", "1"]
