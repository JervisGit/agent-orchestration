FROM python:3.13-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 curl \
    && rm -rf /var/lib/apt/lists/*

COPY ao-core/ ./ao-core/
COPY examples/graph_compliance/backend/ ./backend/
COPY examples/graph_compliance/frontend/ ./frontend/
COPY examples/graph_compliance/ao-manifest.yaml ./ao-manifest.yaml

RUN pip install --no-cache-dir \
    ./ao-core \
    fastapi \
    "uvicorn[standard]" \
    python-multipart \
    python-dotenv \
    python-json-logger \
    networkx

ENV PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD curl -f http://localhost:8003/healthz || exit 1

CMD ["uvicorn", "backend.app:app", "--host", "0.0.0.0", "--port", "8003", "--workers", "1"]
